# =============================================================================
# PasarConnect — Root Environment Variables
# =============================================================================
# This is the SINGLE source of truth for all docker-compose configuration.
# Copy to .env before running:
#
#   cp .env.example .env
#
# Then fill in the secrets marked with  ← CHANGE THIS
# Everything else is pre-filled with safe local-dev defaults.
# =============================================================================


# ── Postgres (shared credentials across all DB instances) ────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Per-database names ────────────────────────────────────────────────────────
INVENTORY_DB_NAME=inventory_db
CLAIM_LOG_DB_NAME=claim_db
PAYMENT_LOG_DB_NAME=payment_db
VERIFICATION_DB_NAME=verification_db

# ── Per-database host/port (internal docker-compose service names) ────────────
INVENTORY_DB_HOST=inventory-db
INVENTORY_DB_PORT=5432
CLAIM_LOG_DB_HOST=claim-log-db
CLAIM_LOG_DB_PORT=5432
PAYMENT_LOG_DB_HOST=payment-log-db
PAYMENT_LOG_DB_PORT=5432
VERIFICATION_DB_HOST=verification-db
VERIFICATION_DB_PORT=5432


# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASS=guest


# ── Internal gRPC addresses ───────────────────────────────────────────────────
# These must match the service names in docker-compose.yaml exactly.
# Only change these if you rename a service.
INVENTORY_GRPC_HOST=inventory-service
INVENTORY_GRPC_PORT=50051

CLAIM_LOG_GRPC_HOST=claim-log-service
CLAIM_LOG_GRPC_PORT=50061

PAYMENT_LOG_GRPC_HOST=payment-log-service
PAYMENT_LOG_GRPC_PORT=50062

VERIFICATION_GRPC_HOST=verification-service
VERIFICATION_GRPC_PORT=50052


# ── Internal HTTP addresses ───────────────────────────────────────────────────
STRIPE_WRAPPER_URL=http://stripe-wrapper:8004


# ── JWT public key (RS256, exported from OutSystems) ──────────────────────────
# Path inside the container — mounted via docker-compose volumes.
PUBLIC_KEY_PATH=/app/keys/public.pem


# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_with_real_key    # ← CHANGE THIS


# ── OutSystems / Verification Service ─────────────────────────────────────────
# Your OutSystems environment base URL — no trailing slash
OUTSYSTEMS_API_URL=https://your-env.outsystemscloud.com    # ← CHANGE THIS

# API key sent as X-API-Key on every request to OutSystems
OUTSYSTEMS_API_KEY=replace-with-real-key                   # ← CHANGE THIS

# Fail-fast timeout (seconds) so OutSystems never hangs the claim flow
OUTSYSTEMS_TIMEOUT_SECONDS=5.0

# ── Verification policy ───────────────────────────────────────────────────────
MAX_DAILY_CLAIMS=5          # max claim approvals per charity per day (anti-hoarding)
MAX_NOSHOWS=3               # no-shows in NOSHOWS_WINDOW_DAYS before cooldown is triggered
NOSHOWS_WINDOW_DAYS=30      # rolling window for no-show pattern detection
BASE_COOLDOWN_DAYS=14       # first ban cooldown; doubles each subsequent ban


# ── Mock mode ─────────────────────────────────────────────────────────────────
# MOCK_OUTSYSTEMS=true  → skip real OutSystems HTTP; use hardcoded response
# MOCK_OUTSYSTEMS_APPROVED=true/false  → control what the mock returns
#
# Set both to false in production.
MOCK_OUTSYSTEMS=true
MOCK_OUTSYSTEMS_APPROVED=true
