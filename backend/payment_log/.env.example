# Payment Log Service — local development environment
# Copy this file to .env and fill in your values.
# When running via docker-compose, these are injected automatically.

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=payment_db

# ── gRPC server port this service listens on ────────────────────────────────
PAYMENT_LOG_GRPC_PORT=50062
