# Claim Service (Orchestrator) — local development environment
# Copy this file to .env and fill in your values.
# When running via docker-compose, these are injected automatically.

# ── Waitlist Service ─────────────────────────────────────────────────────────
WAITLIST_SERVICE_URL=http://localhost:8010

# ── Cancellation grace window ────────────────────────────────────────────────
# If a charity cancels within this many minutes the daily quota slot is restored.
# Use 1 for local testing, 15 for production.
CANCEL_WINDOW_MINUTES=15




# ── Inventory gRPC ──────────────────────────────────────────────────────────
INVENTORY_GRPC_HOST=localhost
INVENTORY_GRPC_PORT=50051

# ── Verification gRPC (OutSystems adapter) ──────────────────────────────────
VERIFICATION_GRPC_HOST=localhost
VERIFICATION_GRPC_PORT=50052

# ── Claim Log gRPC ──────────────────────────────────────────────────────────
CLAIM_LOG_GRPC_HOST=localhost
CLAIM_LOG_GRPC_PORT=50061

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost

# ── JWT public key (RS256, exported from OutSystems) ────────────────────────
# Path to the public.pem file mounted into the container.
PUBLIC_KEY_PATH=../../keys/public.pem