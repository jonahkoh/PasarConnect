# Claim Service (Orchestrator) — owns the waitlist_entries table.

# Waitlist PostgreSQL (can share the claim_log DB or be separate)
WAITLIST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/claim_db

# Inventory gRPC address
INVENTORY_GRPC_HOST=localhost
INVENTORY_GRPC_PORT=50051

# Verification gRPC address
VERIFICATION_GRPC_HOST=localhost
VERIFICATION_GRPC_PORT=50052

# Claim Log Service endpoint
CLAIM_LOG_URL=http://localhost:8006

# RabbitMQ
RABBITMQ_HOST=localhost
