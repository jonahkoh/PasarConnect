# Verification Service (OutSystems adapter) — local development environment
# Copy this file to .env and fill in your values.
# When running via docker-compose, these are injected automatically.

# ── OutSystems REST endpoints ────────────────────────────────────────────────
# UserAuth base URL — public login/register endpoints (no API key required)
# Full path: https://<env>.outsystemscloud.com/PasarConnectAuth/rest/UserAuth
OUTSYSTEMS_API_URL=https://your-env.outsystemscloud.com/PasarConnectAuth/rest/UserAuth

# AdminAuth base URL — approve/reject endpoints (X-API-Key required)
# Full path: https://<env>.outsystemscloud.com/PasarConnectAuth/rest/AdminAuth
OUTSYSTEMS_ADMIN_URL=https://your-env.outsystemscloud.com/PasarConnectAuth/rest/AdminAuth

# API key for AdminAuth endpoints only (shared by OutSystems groupmate)
OUTSYSTEMS_ADMIN_API_KEY=replace-with-real-key

# Timeout for OutSystems HTTP calls (seconds)
OUTSYSTEMS_TIMEOUT_SECONDS=5.0

# ── Verification gRPC (for GetCharityStatus call after login) ────────────────
VERIFICATION_GRPC_HOST=localhost
VERIFICATION_GRPC_PORT=50052

# ── Mock mode (local dev only — skip real OutSystems HTTP calls) ─────────────
MOCK_OUTSYSTEMS=true
MOCK_OUTSYSTEMS_APPROVED=true
