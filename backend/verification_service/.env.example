# Verification Service — local development environment
# Copy this file to .env and fill in your values.
# When running via docker-compose these are injected automatically.

# ── gRPC server port ─────────────────────────────────────────────────────────
VERIFICATION_GRPC_PORT=50052

# ── PostgreSQL quota database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/verification_db

# ── Daily quota limits ────────────────────────────────────────────────────────
MAX_DAILY_CLAIMS=5      # max claims a charity can make per day (anti-hoarding)
MAX_DAILY_PURCHASES=3   # max marketplace purchases a public user can make per day

# ── OutSystems REST endpoint ──────────────────────────────────────────────────
OUTSYSTEMS_API_URL=https://your-env.outsystemscloud.com
OUTSYSTEMS_API_KEY=replace-with-real-key
OUTSYSTEMS_TIMEOUT_SECONDS=5.0

# ── Mock mode (local dev only — skip real OutSystems HTTP calls) ──────────────
MOCK_OUTSYSTEMS=true
MOCK_OUTSYSTEMS_APPROVED=true

# ── JWT public key path (shared with Claim Service) ───────────────────────────
PUBLIC_KEY_PATH=/app/keys/public.pem
