# Verification Service — local development environment
# Copy this file to .env and fill in your values.
# When running via docker-compose these are injected automatically.
#
# NOTE: OutSystems auth (login / JWT) is handled by the outsystems-service, not here.

# ── gRPC server port ─────────────────────────────────────────────────────────
VERIFICATION_GRPC_PORT=50052

# ── PostgreSQL quota database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/verification_db

# ── Anti-hoarding quota ───────────────────────────────────────────────────────
MAX_DAILY_CLAIMS=5       # max claims a charity can make per day

# ── Anti-scalping quota ───────────────────────────────────────────────────────
MAX_DAILY_PURCHASES=3    # max marketplace purchases a public user can make per day

# ── No-show policy ────────────────────────────────────────────────────────────
MAX_NOSHOWS=3            # no-shows allowed before a charity is temporarily banned
NOSHOWS_WINDOW_DAYS=30   # rolling window over which no-shows are counted

# ── JWT public key path (RS256, shared with Claim Service) ───────────────────
PUBLIC_KEY_PATH=/app/keys/public.pem
