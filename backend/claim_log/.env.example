# Claim Log Service — local development environment
# Copy this file to .env and fill in your values.
# When running via docker-compose, these are injected automatically.

# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5434
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=claim_db

# ── gRPC server port this service listens on ────────────────────────────────
CLAIM_LOG_GRPC_PORT=50061
