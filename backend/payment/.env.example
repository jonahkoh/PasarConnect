# Payment Service — local development environment
# Copy this file to .env and fill in your values.

# NOTE: Payment Orchestrator is stateless.
# It does not own a database; persistence lives in payment_log service.

# ── Inventory gRPC ──────────────────────────────────────────────────────────
INVENTORY_GRPC_HOST=localhost
INVENTORY_GRPC_PORT=50051

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost

# ── Internal downstream services (HTTP) ─────────────────────────────────────
STRIPE_WRAPPER_URL=http://localhost:8004
PAYMENT_LOG_URL=http://localhost:8005
