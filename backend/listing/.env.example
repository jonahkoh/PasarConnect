# Listing Service — local development environment
# Copy this file to .env and fill in your values.
# When running via docker-compose, these are injected automatically.
# This file is only needed when running the service standalone (e.g. uvicorn listing:app)

# ── Inventory gRPC ──────────────────────────────────────────────────────────
INVENTORY_GRPC_HOST=localhost
INVENTORY_GRPC_PORT=50051

# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
